#########################################################
# Application
#########################################################

APP_NAME=Student Achievement Dashboard

ENVIRONMENT=production

SECRET_KEY=replace_with_64_character_random_string

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=480


#########################################################
# PostgreSQL
#########################################################

POSTGRES_DB=assessment

POSTGRES_USER=assessment

POSTGRES_PASSWORD=SuperSecureDatabasePassword


#########################################################
# Database Connection
#########################################################

DATABASE_URL=postgresql+psycopg://assessment:SuperSecureDatabasePassword@postgres:5432/assessment


#########################################################
# Redis
#########################################################

REDIS_URL=redis://redis:6379/0


#########################################################
# Entra ID Authentication
#########################################################

ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

ENTRA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

ENTRA_AUTHORITY=https://login.microsoftonline.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

ENTRA_REDIRECT_URI=https://dashboard.mtparanschool.com/auth/callback


#########################################################
# Microsoft Graph
#########################################################

GRAPH_SCOPE=https://graph.microsoft.com/.default

GRAPH_API_BASE=https://graph.microsoft.com/v1.0


#########################################################
# Canvas
#########################################################

CANVAS_BASE_URL=https://mtparanschool.instructure.com

CANVAS_TOKEN=canvas_api_token_here

CANVAS_ACCOUNT_ID=1


#########################################################
# File Storage
#########################################################

UPLOAD_DIRECTORY=/app/uploads

IMPORT_DIRECTORY=/app/imports

MAX_UPLOAD_SIZE_MB=100


#########################################################
# Logging
#########################################################

LOG_LEVEL=INFO

LOG_FILE=/app/logs/application.log


#########################################################
# Email (Optional)
#########################################################

SMTP_SERVER=smtp.office365.com

SMTP_PORT=587

SMTP_USERNAME=dashboard@mtparanschool.com

SMTP_PASSWORD=replace_me

SMTP_FROM=dashboard@mtparanschool.com


#########################################################
# Assessment Imports
#########################################################

SAT_IMPORT_PATH=/app/uploads/SAT

PSAT_IMPORT_PATH=/app/uploads/PSAT

ACT_IMPORT_PATH=/app/uploads/ACT

MAP_IMPORT_PATH=/app/uploads/MAP

DIBELS_IMPORT_PATH=/app/uploads/DIBELS


#########################################################
# Group Names
#########################################################

GROUP_ADMINS=Assessment_Admins

GROUP_COUNSELORS=Assessment_Counselors

GROUP_LOWER_SCHOOL=Assessment_LS

GROUP_MIDDLE_SCHOOL=Assessment_MS

GROUP_HIGH_SCHOOL=Assessment_HS

GROUP_GRADE_9=Assessment_Grade9

GROUP_GRADE_10=Assessment_Grade10

GROUP_GRADE_11=Assessment_Grade11

GROUP_GRADE_12=Assessment_Grade12


#########################################################
# Student Sync
#########################################################

STUDENT_SYNC_SOURCE=ad

AD_BASE_DN=OU=zUsers,DC=mpcs,DC=mtparanschool,DC=com

AD_SERVER=dc01.mpcs.mtparanschool.com

AD_BIND_USER=svc_dashboard@mpcs.mtparanschool.com

AD_BIND_PASSWORD=replace_me


#########################################################
# Scheduler
#########################################################

CANVAS_SYNC_ENABLED=true

CANVAS_SYNC_HOUR=2

STUDENT_SYNC_HOUR=1

IMPORT_SCAN_INTERVAL_MINUTES=60


GROUP_ASSESSMENT_ADMINS=3f9852d1-xxxx-xxxx-xxxx-xxxxxxxxxxxx

GROUP_ASSESSMENT_COUNSELORS=4e332a21-xxxx-xxxx-xxxx-xxxxxxxxxxxx

GROUP_ASSESSMENT_LS=7b881aa1-xxxx-xxxx-xxxx-xxxxxxxxxxxx

GROUP_ASSESSMENT_MS=8a772cd1-xxxx-xxxx-xxxx-xxxxxxxxxxxx

GROUP_ASSESSMENT_HS=9c5549e1-xxxx-xxxx-xxxx-xxxxxxxxxxxx